{
  "name": "devupai",
  "version": "2.1.3",
  "description": "Official Node.js SDK for DEVUP AI — OpenAI-compatible inference gateway with DZD billing",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./ai": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.mjs",
      "require": "./dist/provider.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "devupai",
    "ai",
    "llm",
    "inference",
    "embeddings",
    "openai-compatible",
    "algeria",
    "dzd",
    "vercel-ai-sdk"
  ],
  "author": "DEVUP AI",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@ai-sdk/openai-compatible": ">=2.0.0",
    "@ai-sdk/provider": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/openai-compatible": {
      "optional": true
    },
    "@ai-sdk/provider": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/provider.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/provider.ts --format cjs,esm --dts --watch"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@ai-sdk/provider": "^3.0.10",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
